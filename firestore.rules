rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && (request.auth.token.email.lower() == "aliaezatwork@gmail.com");
    }

    function isAdmin() {
      // TEMPORARY: Allow all signed in users for debugging
      // return isBootstrapAdmin() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Lessons ---
    match /lessons/{lessonId} {
      function isValidLesson(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 2000 &&
               data.videoType in ['youtube', 'file'] &&
               (data.youtubeId == null || (data.youtubeId is string && data.youtubeId.size() <= 128) || data.youtubeId == "") &&
               (data.videoUrl == null || (data.videoUrl is string && data.videoUrl.size() <= 1000) || data.videoUrl == "") &&
               data.category in ['arabic', 'english'] &&
               (data.level == null || data.level is string) &&
               (data.duration == null || data.duration is string) &&
               (data.thumbnail == null || data.thumbnail is string) &&
               (data.pdfUrl == null || data.pdfUrl is string) &&
               (data.order == null || data.order is number);
      }

      // Everyone can read lessons
      allow read: if true;
      
      // Admins can write lessons
      allow create: if isAdmin() && isValidLesson(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Students ---
    match /students/{studentId} {
      function isValidStudent(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }

      // Admins can manage students
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidStudent(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Admin Collection ---
    match /admins/{adminId} {
      allow read: if isSignedIn(); // Allow everyone to check if they are admin
      allow write: if false; // Admins are managed manually via Firebase Console
    }
  }
}
